---
import Layout from '../layouts/Layout.astro';
import { getManifest } from '../lib/manifest';

const manifest = getManifest();
const baseUrl = 'https://icontree.cosmoscope.workers.dev';

const searchResponseExample = `GET ${baseUrl}/icon/search?q=arrow&page=1&pageSize=20

{
  "query": "arrow",
  "category": "",
  "count": 12,
  "results": [
    {
      "name": "arrow-right-bold",
      "slug": "arrow-right-bold",
      "filename": "arrow-right-bold.json",
      "tags": ["arrow", "direction", "ui"],
      "category": "navigation",
      "size": 1583,
      "url": "/icon/use/arrow-right-bold.json"
    }
  ]
}`;

const androidSetupExample = `// settings.gradle / build.gradle
// Add the current Lottie Android dependency for your project.
implementation("com.airbnb.android:lottie:<latest-version>")`;

const androidExample = `suspend fun loadIconTreeAnimation(query: String): String? {
    val searchUrl = "${baseUrl}/icon/search?q=$" + "{URLEncoder.encode(query, "UTF-8")}&page=1&pageSize=20"
    val searchText = URL(searchUrl).readText()
    val searchJson = JSONObject(searchText)
    val results = searchJson.getJSONArray("results")

    if (results.length() == 0) return null

    val first = results.getJSONObject(0)
    return "${baseUrl}$" + "{first.getString("url")}"
}

// Then pass the returned URL to Lottie:
// lottieView.setAnimationFromUrl(iconUrl)`;

const jsExample = `const search = await fetch(
  "${baseUrl}/icon/search?q=arrow&page=1&pageSize=20"
).then((r) => r.json());

const firstIcon = search.results[0];
const animationData = await fetch("${baseUrl}" + firstIcon.url).then((r) => r.json());

lottie.loadAnimation({
  container: document.getElementById("icon"),
  renderer: "svg",
  loop: true,
  autoplay: true,
  animationData,
});`;

const reactExample = `import { useEffect, useRef } from "react";
import lottie from "lottie-web";

export function IconTreePreview({ slug }) {
  const containerRef = useRef(null);

  useEffect(() => {
    let animation;

    async function load() {
      const data = await fetch("${baseUrl}/icon/use/" + slug + ".json").then((r) => r.json());

      animation = lottie.loadAnimation({
        container: containerRef.current,
        renderer: "svg",
        loop: true,
        autoplay: true,
        animationData: data,
      });
    }

    load();
    return () => animation?.destroy();
  }, [slug]);

  return <div ref={containerRef} style={{ width: 32, height: 32 }} />;
}`;

const nodeExample = `const response = await fetch(
  "${baseUrl}/icon/search?q=mail&category=communication&page=1&pageSize=20"
);
const data = await response.json();

console.log(data.results.map((icon) => ({
  name: icon.name,
  jsonUrl: "${baseUrl}" + icon.url,
})));`;

const pythonExample = `import requests

search = requests.get(
    "${baseUrl}/icon/search",
    params={"q": "search", "page": 1, "pageSize": 20},
).json()

if search["results"]:
    first = search["results"][0]
    icon_json = requests.get("${baseUrl}" + first["url"]).json()
    print(first["name"], icon_json["v"])`;

const curlExample = `curl "${baseUrl}/icon/search?q=arrow&page=1&pageSize=20"`;

const androidManualExample = `// Put the file in:
// app/src/main/assets/lottie/arrow-right-bold.json

lottieView.setAnimation("lottie/arrow-right-bold.json")
lottieView.playAnimation()`;

const reactManualExample = `import lottie from "lottie-web";
import animationData from "./lottie/arrow-right-bold.json";

lottie.loadAnimation({
  container: document.getElementById("icon"),
  renderer: "svg",
  loop: true,
  autoplay: true,
  animationData,
});`;

const manualSteps = `Manual mode means:
1. Pick an icon on IconTree
2. Download or copy its .json file
3. Save it inside your app project
4. Load that local file with your platform's Lottie player

Use manual mode when you already know which icons you want and do not need runtime search.`;
---

<Layout title="IconTree - Docs">
  <div class="doc-content doc-content-wide">
    <div class="doc-nav">
      <a href="/" class="back-link">&lt; Back</a>
    </div>

    <section class="doc-hero">
      <span class="doc-kicker">Docs</span>
      <h1>IconTree Integration Docs</h1>
      <p class="doc-lead">
        These docs are for adding IconTree icons into an existing app. Pick icons with the search API, then ship them
        as local Lottie JSON rendered by your platform’s Lottie player.
      </p>
    </section>

    <section class="doc-callout">
      <p><strong>Base URL</strong></p>
      <pre><code>{baseUrl}</code></pre>
      <p>
        IconTree only serves <strong>Lottie animation JSON</strong> — there is no SVG format. Every icon is a
        <code>.json</code> file passed to a Lottie player. Search returns a relative <code>url</code> like
        <code>/icon/use/arrow-right-bold.json</code>; build the full URL with <code>{baseUrl} + result.url</code>.
      </p>
    </section>

    <h2>Format Note</h2>
    <p>
      Do not write SVG-loading, SVG-parsing, or SVG-fallback code for these icons. There is no SVG available from this
      source — every icon, in both modes below, is a <code>.json</code> file passed to the platform’s Lottie player
      component.
    </p>

    <h2>How IconTree Works</h2>
    <p>Integration is a two-step flow: <strong>select</strong> at design time, then <strong>ship locally</strong>.</p>
    <ol>
      <li>Search the library with <code>/icon/search</code> (you, the developer — not the running app).</li>
      <li>Pick the icons you need from <code>results[]</code>.</li>
      <li>Download each icon’s JSON (fetch <code>{baseUrl} + result.url</code>) and bundle it into your app.</li>
      <li>Load the bundled JSON the idiomatic way for your stack and render it with a Lottie player.</li>
    </ol>
    <p>
      The shipped app should <strong>never</strong> call <code>/icon/search</code> at runtime. Selection happens once,
      while you author the code; the final code is local and static.
    </p>

    <h2>Mode 2 — Manual / Local (recommended for shipped apps)</h2>
    <p>
      You do not have to call the API at runtime. Once you have selected and downloaded the JSON files (using the
      search endpoint at design time), keep them inside your app and load them locally.
    </p>
    <pre><code>{manualSteps}</code></pre>

    <div class="lang-grid">
      <section class="lang-card">
        <h3>Android Manual</h3>
        <p>Store the JSON file in your app assets folder, then load it directly into <code>LottieAnimationView</code>.</p>
        <pre><code>{androidManualExample}</code></pre>
      </section>

      <section class="lang-card">
        <h3>React / Web Manual</h3>
        <p>Import the downloaded JSON file into your app and pass it straight to <code>lottie-web</code>.</p>
        <pre><code>{reactManualExample}</code></pre>
      </section>
    </div>

    <h2>Search Response Shape</h2>
    <pre><code>{searchResponseExample}</code></pre>

    <h2>Endpoint Reference</h2>

    <div class="endpoint-block">
      <div class="endpoint-header">
        <span class="method">GET</span>
        <span class="endpoint-path">/icon/search</span>
      </div>
      <p>Search by icon name, tags, or category. Use this at design time to <strong>pick</strong> icons — not from the shipped app.</p>
      <ul>
        <li><code>q</code> - Search text.</li>
        <li><code>category</code> - Optional category filter.</li>
        <li><code>page</code> - Page number.</li>
        <li><code>pageSize</code> - Batch size. Use <code>20</code> for scrolling UIs.</li>
      </ul>
    </div>

    <div class="endpoint-block">
      <div class="endpoint-header">
        <span class="method">GET</span>
        <span class="endpoint-path">/icon/use/&lt;iconname&gt;.json</span>
      </div>
      <p>Returns the raw Lottie JSON for one icon.</p>
      <ul>
        <li><code>color</code> - Optional hex color (e.g. <code>%23ff0000</code>). Recolors the icon’s fill/stroke to match your theme. URL-encode the leading <code>#</code>.</li>
      </ul>
    </div>

    <h2>Platform Guides</h2>
    <p>
      The snippets below show how to <strong>fetch an icon at design time</strong> (to download and bundle it). For the
      shipped app, load the bundled JSON locally and render it with your Lottie player — do not keep the fetch in
      production code.
    </p>

    <div class="lang-grid">
      <section class="lang-card">
        <h3>Android</h3>
        <p>Add a Lottie Android dependency, search IconTree, then load the returned JSON URL into your Lottie view.</p>
        <pre><code>{androidSetupExample}</code></pre>
        <pre><code>{androidExample}</code></pre>
      </section>

      <section class="lang-card">
        <h3>JavaScript</h3>
        <p>Search the API, fetch the raw JSON, and hand it to <code>lottie-web</code>.</p>
        <pre><code>{jsExample}</code></pre>
      </section>

      <section class="lang-card">
        <h3>React</h3>
        <p>Fetch the icon JSON inside an effect and destroy the animation on unmount.</p>
        <pre><code>{reactExample}</code></pre>
      </section>

      <section class="lang-card">
        <h3>Node.js</h3>
        <p>Useful for server-side search, tooling, CMS integrations, or icon picking workflows.</p>
        <pre><code>{nodeExample}</code></pre>
      </section>

      <section class="lang-card">
        <h3>Python</h3>
        <p>Good for scripts, backend workflows, dataset generation, or asset prep pipelines.</p>
        <pre><code>{pythonExample}</code></pre>
      </section>

      <section class="lang-card">
        <h3>curl</h3>
        <p>Use this for quick testing before wiring the API into your app.</p>
        <pre><code>{curlExample}</code></pre>
      </section>
    </div>

    <h2>Best Practices</h2>
    <ul>
      <li>Use the search API to <strong>select</strong> icons at design time; ship them as local JSON (Mode 2).</li>
      <li>The running app should never call <code>/icon/search</code> — bundle the icons instead.</li>
      <li>IconTree is Lottie-JSON only: no SVG loading/parsing/fallback code.</li>
      <li>Recolor icons to your theme — the source JSON often ships a fixed fill (white/black) that won’t match light/dark.</li>
      <li>Use <code>pageSize=20</code> when scrolling the search results during selection.</li>
      <li>Keep the original <code>name</code> and <code>slug</code> returned by the API.</li>
      <li>Cache fetched icon JSON where possible. Responses are immutable per build.</li>
      <li>If search returns no results, try a broader query or remove the category filter.</li>
    </ul>

    <h2>Icon Color / Theming</h2>
    <p>
      IconTree icons ship with a fixed fill color baked into the Lottie JSON (often white or black) that is
      <strong>not</strong> guaranteed to match your app’s theme. Recolor the icon to your existing icon/theme token
      using the idiomatic mechanism for your platform’s Lottie player — e.g. runtime color callbacks / dynamic
      properties, <code>colorFilters</code>, or a JSON preprocessing step that swaps fill/stroke color values before
      passing the data to the player. The resulting color must follow your app’s current theme (light/dark/custom),
      not the source JSON’s color.
    </p>

    <h2>Source &amp; Repository</h2>
    <p>
      IconTree is open source. Grab the code, report issues, or contribute new icons on GitHub:
    </p>
    <p>
      <a class="doc-repo-link" href="https://github.com/HasibulHasan098/IconTree" target="_blank" rel="noopener noreferrer">
        https://github.com/HasibulHasan098/IconTree
      </a>
    </p>

    <p style="margin-top: 48px; color: var(--color-text-muted); font-size: 0.875rem;">
      IconTree v1 · {manifest.total.toLocaleString()} icons available ·{' '}
      <a href="https://github.com/HasibulHasan098/IconTree" target="_blank" rel="noopener noreferrer">GitHub</a>
    </p>
  </div>

  <script>
    (function() {
      const preBlocks = Array.from(document.querySelectorAll('.doc-content pre')) as HTMLElement[];

      preBlocks.forEach((pre: HTMLElement) => {
        const btn = document.createElement('button');
        btn.className = 'copy-snippet-btn';
        btn.textContent = 'Copy';
        btn.type = 'button';
        pre.style.position = 'relative';
        pre.appendChild(btn);

        btn.addEventListener('click', () => {
          const code = pre.querySelector('code');
          const text = code?.textContent || '';

          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = 'Copied!';
            btn.classList.add('copied');

            setTimeout(() => {
              btn.textContent = 'Copy';
              btn.classList.remove('copied');
            }, 2000);
          });
        });
      });
    })();
  </script>
</Layout>
