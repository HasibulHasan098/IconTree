---
import Layout from '../layouts/Layout.astro';
import { getManifest } from '../lib/manifest';
import IconCard from '../components/IconCard.astro';
import SearchBar from '../components/SearchBar.astro';
import FilterChips from '../components/FilterChips.astro';

const manifest = getManifest();
const categoryCounts = manifest.icons.reduce<Record<string, number>>((acc, icon) => {
  acc[icon.category] = (acc[icon.category] || 0) + 1;
  return acc;
}, {});

const categories = Object.entries(categoryCounts)
  .map(([name, count]) => {
    const sampleIcon = manifest.icons.find(icon => icon.category === name);
    return {
      name,
      count,
      iconUrl: sampleIcon?.url,
      iconSlug: sampleIcon?.slug,
      iconName: sampleIcon?.name,
    };
  })
  .sort((a, b) => b.count - a.count);

const PAGE_SIZE = 100;
const initialIcons = manifest.icons.slice(0, PAGE_SIZE);
const allIcon = manifest.icons[0];
const allIconsJson = JSON.stringify(manifest.icons);
---

<Layout title="IconTree - Animated Icon Library">
  <header class="page-header">
    <div class="container">
      <h1>IconTree</h1>
      <p>{manifest.total.toLocaleString()} animated Lottie icons - search, preview, copy.</p>
    </div>
  </header>

  <main>
    <div class="container">
      <SearchBar />

      <FilterChips
        categories={categories}
        total={manifest.total}
        allIcon={allIcon ? { url: allIcon.url, slug: allIcon.slug, name: allIcon.name } : undefined}
      />

      <div id="icon-grid" class="icon-grid">
        {initialIcons.map(icon => (
          <IconCard name={icon.name} slug={icon.slug} url={icon.url} />
        ))}
      </div>
      <div id="scroll-sentinel" class="scroll-sentinel" aria-hidden="true"></div>

      <div id="empty-state" class="empty-state" style="display: none;">
        <h3>No icons found</h3>
        <p>Try a different search term or clear your filters.</p>
      </div>
    </div>
  </main>

  <aside id="cart-panel" class="cart-panel" aria-label="Selected icons">
    <div class="cart-panel-header">
      <h3>Selected Icons (<span id="cart-count">0</span>)</h3>
      <button id="cart-clear" class="cart-clear" title="Clear all">Clear</button>
    </div>
    <div id="cart-items" class="cart-items"></div>
    <div class="cart-empty" id="cart-empty">No icons yet. Click + on any icon to add it here.</div>
    <div class="cart-panel-footer">
      <div class="cart-color-row">
        <div class="cart-color-picker">
          <button id="cart-color-btn" class="cart-color-btn" aria-label="Recolor icons" title="Recolor icons">
            <span class="cart-color-swatch" id="cart-color-swatch" style="background:#000000"></span>
            <span class="cart-color-text">Black</span>
          </button>
          <div id="cart-color-pop" class="cart-color-pop" hidden>
            <div class="cart-color-swatches" id="cart-color-swatches"></div>
            <div id="cart-color-wheel" class="cart-color-wheel"></div>
            <div class="cart-color-hex">
              <span>#</span>
              <input type="text" id="cart-color-hex" class="cart-color-hex-input" value="000000" maxlength="6" aria-label="Hex color" />
            </div>
          </div>
        </div>
        <button id="cart-download" class="cart-download" disabled>
          Download <span id="cart-download-count">0</span> icon<span id="cart-download-s">s</span>
        </button>
      </div>
    </div>
  </aside>
  <script is:inline define:vars={{ allIconsData: allIconsJson }}>
    window.__ICON_MANIFEST__ = JSON.parse(allIconsData);
  </script>

  <script>
    (function() {
      const ALL_ICONS = (window.__ICON_MANIFEST__ || []) as Array<{ name: string; slug: string; url: string; tags: string[]; category: string }>;
      const grid = document.getElementById('icon-grid');
      const emptyState = document.getElementById('empty-state');
      const scrollSentinel = document.getElementById('scroll-sentinel');
      const PAGE_SIZE = 100;
      let currentQuery = '';
      let currentCategory = '';
      let currentPage = 1;
      let filteredIcons: Array<{ name: string; slug: string; url: string }> = ALL_ICONS.slice();
      let loadedCount = grid ? grid.children.length : 0;
      let hasMore = loadedCount < filteredIcons.length;
      let isLoading = false;

      function getFilteredIcons(): Array<{ name: string; slug: string; url: string }> {
        const q = currentQuery.toLowerCase().trim();
        let list = ALL_ICONS;
        if (currentCategory) {
          list = list.filter(icon => icon.category === currentCategory);
        }
        if (q) {
          list = list.filter(icon =>
            icon.name.toLowerCase().includes(q) ||
            (icon.tags || []).some(t => t.toLowerCase().includes(q)) ||
            icon.category.toLowerCase().includes(q)
          );
        }
        return list;
      }

      function fetchIcons(page: number): { count: number; results: Array<{ name: string; slug: string; url: string }> } {
        const start = (page - 1) * PAGE_SIZE;
        const results = filteredIcons.slice(start, start + PAGE_SIZE);
        return { count: filteredIcons.length, results };
      }

      function createIconMarkup(icon: { name: string; slug: string; url: string }) {
        return `
          <div class="icon-card" tabindex="0" role="button" aria-label="Add ${icon.name} to selection">
            <div class="icon-preview" data-slug="${icon.slug}" data-url="${icon.url}" data-name="${icon.name}" role="img" aria-label="${icon.name} animation preview"></div>
            <div class="icon-actions">
              <button class="add-btn" data-add name="${icon.name}" slug="${icon.slug}" url="${icon.url}" aria-label="Add ${icon.name} to selection" title="Add to selection">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </button>
            </div>
            <span class="icon-name">${icon.name}</span>
          </div>
        `;
      }

      function updateScrollState() {
        if (!scrollSentinel) return;
        scrollSentinel.style.display = hasMore ? 'block' : 'none';
      }

      function renderIcons(icons: Array<{ name: string; slug: string; url: string }>, replace = true) {
        if (!grid) return;

        if (icons.length === 0) {
          grid.style.display = 'none';
          grid.innerHTML = '';
          if (emptyState) emptyState.style.display = 'block';
          loadedCount = 0;
          hasMore = false;
          updateScrollState();
          return;
        }

        grid.style.display = 'grid';
        if (emptyState) emptyState.style.display = 'none';

        const wrapper = document.createElement('div');
        wrapper.innerHTML = icons.map(createIconMarkup).join('');
        const newCards = Array.from(wrapper.children) as HTMLElement[];

        if (replace) {
          grid.innerHTML = '';
        }

        newCards.forEach((card) => grid.appendChild(card));
        loadedCount = grid.children.length;
        setupCardInteractions(newCards);
        hasMore = loadedCount < filteredIcons.length;
        updateScrollState();
      }

      function setupCardInteractions(cards: HTMLElement[]) {
        cards.forEach((card: HTMLElement) => {
          if (card.dataset.enhanced === 'true') return;
          card.dataset.enhanced = 'true';

          const preview = card.querySelector('.icon-preview') as HTMLElement | null;
          const url = preview?.getAttribute('data-url') || '';
          let animation: any = null;
          let loaded = false;
          let stage: HTMLDivElement | null = null;

          async function loadAnimation(container: HTMLElement): Promise<void> {
            if (loaded || !url) return;

            while (!(window as any).lottie) {
              await new Promise(r => setTimeout(r, 50));
            }

            loaded = true;

            stage = document.createElement('div');
            stage.className = 'icon-preview-stage';
            container.appendChild(stage);

            try {
              const response = await fetch(url);
              const data = await response.json();

              animation = (window as any).lottie.loadAnimation({
                container: stage,
                renderer: 'svg',
                loop: true,
                autoplay: true,
                animationData: data,
                rendererSettings: {
                  preserveAspectRatio: 'xMidYMid meet',
                  progressiveLoad: true,
                }
              });
            } catch (e) {
              loaded = false;
              if (stage?.parentNode) stage.parentNode.removeChild(stage);
              stage = null;
            }
          }

          function stopAnimation(container: HTMLElement): void {
            if (animation) {
              animation.stop();
              animation.destroy();
              animation = null;
            }
            loaded = false;

            const currentStage = stage ?? container.querySelector('.icon-preview-stage');
            if (currentStage && currentStage.parentNode) currentStage.parentNode.removeChild(currentStage);
            stage = null;
          }

          preview?.addEventListener('mouseenter', () => loadAnimation(preview));
          preview?.addEventListener('focus', () => loadAnimation(preview));

          const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                loadAnimation(preview);
              } else {
                stopAnimation(preview);
              }
            });
          }, { rootMargin: '0px', threshold: 0.1 });

          io.observe(preview);

          function addToCart(e: Event): void {
            e.stopPropagation();
            window.dispatchEvent(new CustomEvent('iconadd', {
              detail: { url, name, slug },
            }));
            const addBtn = card.querySelector('.add-btn') as HTMLElement | null;
            if (addBtn) {
              addBtn.classList.add('added');
              setTimeout(() => addBtn.classList.remove('added'), 600);
            }
          }

          const addBtn = card.querySelector('.add-btn') as HTMLElement | null;
          addBtn?.addEventListener('click', addToCart);

          card.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              addToCart(e);
            }
          });
        });
      }

      async function loadPage(page: number, replace = true) {
        if (isLoading) return;

        isLoading = true;

        try {
          const data = fetchIcons(page);
          currentPage = page;
          renderIcons(data.results, replace);
        } catch (e) {
          console.error('Failed to load icons:', e);
        } finally {
          isLoading = false;
        }
      }

      async function loadNextPage() {
        if (!hasMore || isLoading) return;
        await loadPage(currentPage + 1, false);
      }

      const scrollObserver = scrollSentinel ? new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            loadNextPage();
          }
        });
      }, { rootMargin: '260px 0px', threshold: 0.01 }) : null;

      if (scrollObserver && scrollSentinel) {
        scrollObserver.observe(scrollSentinel);
      }

      updateScrollState();

      window.addEventListener('iconsearch', async (e: any) => {
        currentQuery = e.detail;
        filteredIcons = getFilteredIcons();
        await loadPage(1, true);
      });

      window.addEventListener('iconfilter', async (e: any) => {
        currentCategory = e.detail;
        filteredIcons = getFilteredIcons();
        await loadPage(1, true);
      });

      /* ---------- Selection panel (fixed right) ---------- */
      const cartItems = document.getElementById('cart-items');
      const cartEmpty = document.getElementById('cart-empty');
      const cartCount = document.getElementById('cart-count');
      const cartDownloadCount = document.getElementById('cart-download-count');
      const cartDownloadS = document.getElementById('cart-download-s');
      const cartDownloadBtn = document.getElementById('cart-download') as HTMLButtonElement | null;
      const cartClearBtn = document.getElementById('cart-clear');
      const cartColorBtn = document.getElementById('cart-color-btn');
      const cartColorSwatch = document.getElementById('cart-color-swatch') as HTMLElement | null;
      const cartColorText = document.getElementById('cart-color-text') as HTMLElement | null;
      const cartColorPop = document.getElementById('cart-color-pop');
      const cartColorSwatches = document.getElementById('cart-color-swatches');
      const cartColorWheel = document.getElementById('cart-color-wheel');
      const cartColorHex = document.getElementById('cart-color-hex') as HTMLInputElement | null;

      const PRESET_COLORS: Array<{ name: string; hex: string }> = [
        { name: 'Black', hex: '000000' },
        { name: 'White', hex: 'ffffff' },
        { name: 'Red', hex: 'ef4444' },
        { name: 'Orange', hex: 'f97316' },
        { name: 'Yellow', hex: 'eab308' },
        { name: 'Green', hex: '22c55e' },
        { name: 'Blue', hex: '3b82f6' },
        { name: 'Purple', hex: 'a855f7' },
        { name: 'Pink', hex: 'ec4899' },
      ];

      const selection: Array<{ url: string; name: string; slug: string }> = [];
      const seen = new Set<string>();
      const previews: Array<{ el: HTMLElement; anim: any }> = [];
      let panelColor = '#000000';
      let colorWheel: any = null;

      function slugToFile(slug: string): string {
        return `${slug || 'icon'}.json`;
      }

      function urlWithColor(url: string): string {
        const sep = url.includes('?') ? '&' : '?';
        return `${url}${sep}color=${panelColor.replace(/^#/, '')}`;
      }

      function applyColor(hex: string, name?: string, fromWheel = false): void {
        panelColor = `#${hex.replace(/^#/, '')}`;
        if (cartColorSwatch) cartColorSwatch.style.background = panelColor;
        if (cartColorText) cartColorText.textContent = name || panelColor.toUpperCase();
        if (cartColorHex && !fromWheel) cartColorHex.value = hex.replace(/^#/, '');
        if (colorWheel && !fromWheel) colorWheel.setColors(panelColor);
        destroyPreviews();
        renderCart();
      }

      function buildSwatches(): void {
        if (!cartColorSwatches) return;
        cartColorSwatches.innerHTML = '';
        PRESET_COLORS.forEach((c) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'cart-color-swatch-btn' + (c.hex === '000000' ? ' active' : '');
          b.style.background = `#${c.hex}`;
          b.title = c.name;
          b.setAttribute('aria-label', c.name);
          b.addEventListener('click', () => {
            applyColor(c.hex, c.name);
            cartColorSwatches?.querySelectorAll('.cart-color-swatch-btn').forEach((el) => el.classList.remove('active'));
            b.classList.add('active');
            closePop();
          });
          cartColorSwatches.appendChild(b);
        });
      }

      function openPop(): void {
        cartColorPop?.removeAttribute('hidden');
        if (cartColorWheel && !colorWheel) initWheel();
      }
      function closePop(): void {
        cartColorPop?.setAttribute('hidden', '');
      }

      async function initWheel(): Promise<void> {
        if (!cartColorWheel || colorWheel) return;
        try {
          if (!(window as any).iro) {
            await new Promise<void>((resolve, reject) => {
              const s = document.createElement('script');
              s.src = 'https://cdn.jsdelivr.net/npm/@jaames/iro@5/dist/iro.min.js';
              s.onload = () => resolve();
              s.onerror = () => reject(new Error('Failed to load iro.js'));
              document.head.appendChild(s);
            });
          }
          const Iro = (window as any).iro;
          if (!Iro?.ColorPicker) throw new Error('iro.ColorPicker not found');
          colorWheel = new Iro.ColorPicker(cartColorWheel, {
            width: 180,
            color: panelColor,
            borderWidth: 1,
            borderColor: '#d8d3c7',
            layout: [
              { component: Iro.ui.Wheel },
              { component: Iro.ui.Slider, options: { sliderType: 'value' } },
            ],
          });
          colorWheel.on('input:move', (color: any) => {
            cartColorSwatches?.querySelectorAll('.cart-color-swatch-btn').forEach((el) => el.classList.remove('active'));
            applyColor(color.hexString, color.hexString, true);
          });
        } catch (e) {
          console.error('Color wheel failed to load:', e);
          if (cartColorWheel) cartColorWheel.innerHTML = '<div class="cart-color-fallback">Color wheel unavailable</div>';
        }
      }

      function openPop(): void {
        cartColorPop?.removeAttribute('hidden');
        if (cartColorWheel && !colorWheel) {
          setTimeout(() => { initWheel(); }, 100);
        }
      }

      cartColorBtn?.addEventListener('click', (e: Event) => {
        e.stopPropagation();
        if (cartColorPop?.hasAttribute('hidden')) openPop(); else closePop();
      });

      document.addEventListener('click', (e: Event) => {
        if (!cartColorPop?.hasAttribute('hidden') &&
            !(e.target as HTMLElement).closest('.cart-color-picker')) {
          closePop();
        }
      });

      cartColorPop?.addEventListener('pointerdown', (e) => e.stopPropagation());

      cartColorHex?.addEventListener('input', () => {
        const v = cartColorHex.value.replace(/[^0-9a-fA-F]/g, '').slice(0, 6);
        if (v.length === 6) {
          cartColorSwatches?.querySelectorAll('.cart-color-swatch-btn').forEach((el) => el.classList.remove('active'));
          applyColor(v, `#${v.toUpperCase()}`);
        }
      });

      function renderPreview(stage: HTMLElement, item: { url: string }): void {
        async function load(): Promise<void> {
          while (!(window as any).lottie) {
            await new Promise(r => setTimeout(r, 50));
          }
          try {
            const res = await fetch(urlWithColor(item.url));
            const data = await res.json();
            const anim = (window as any).lottie.loadAnimation({
              container: stage,
              renderer: 'svg',
              loop: true,
              autoplay: true,
              animationData: data,
            });
            previews.push({ el: stage, anim });
          } catch (e) {
            console.error('Preview failed:', e);
          }
        }
        load();
      }

      function renderCart(): void {
        if (!cartItems) return;
        cartItems.innerHTML = '';
        selection.forEach((item, idx) => {
          const card = document.createElement('div');
          card.className = 'cart-item';
          card.innerHTML = `
            <div class="cart-item-preview" data-idx="${idx}"></div>
            <button class="cart-item-remove" data-idx="${idx}" aria-label="Remove ${item.name}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </button>`;
          cartItems.appendChild(card);

          const stage = card.querySelector('.cart-item-preview') as HTMLElement;
          renderPreview(stage, item);
        });

        const n = selection.length;
        if (cartCount) cartCount.textContent = String(n);
        if (cartDownloadCount) cartDownloadCount.textContent = String(n);
        if (cartDownloadS) cartDownloadS.style.display = n === 1 ? 'none' : 'inline';
        if (cartEmpty) cartEmpty.style.display = n === 0 ? 'flex' : 'none';
        if (cartDownloadBtn) cartDownloadBtn.disabled = n === 0;
      }

      function destroyPreviews(): void {
        previews.forEach(p => { try { p.anim?.destroy(); } catch (_) {} });
        previews.length = 0;
      }

      window.addEventListener('iconadd', (e: any) => {
        const { url, name, slug } = e.detail;
        if (seen.has(url)) return;
        seen.add(url);
        selection.push({ url, name, slug });
        renderCart();
      });

      cartItems?.addEventListener('click', (e: Event) => {
        const target = (e.target as HTMLElement).closest('.cart-item-remove') as HTMLElement | null;
        if (!target) return;
        const idx = Number(target.getAttribute('data-idx'));
        const removed = selection.splice(idx, 1)[0];
        if (removed) seen.delete(removed.url);
        destroyPreviews();
        renderCart();
      });

      cartClearBtn?.addEventListener('click', () => {
        selection.length = 0;
        seen.clear();
        destroyPreviews();
        renderCart();
      });

      function triggerDownload(blob: Blob, filename: string): void {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(a.href), 1000);
      }

      function crc32(bytes: Uint8Array): number {
        let crc = ~0;
        for (let i = 0; i < bytes.length; i++) {
          crc ^= bytes[i];
          for (let k = 0; k < 8; k++) {
            crc = (crc >>> 1) ^ (0xEDB88320 & -(crc & 1));
          }
        }
        return ~crc >>> 0;
      }

      function buildZip(files: Array<{ name: string; data: Uint8Array }>): Blob {
        const enc = new TextEncoder();
        const chunks: Uint8Array[] = [];
        const central: Uint8Array[] = [];
        let offset = 0;

        const u16 = (n: number) => new Uint8Array([n & 0xff, (n >>> 8) & 0xff]);
        const u32 = (n: number) => new Uint8Array([n & 0xff, (n >>> 8) & 0xff, (n >>> 16) & 0xff, (n >>> 24) & 0xff]);

        files.forEach((f) => {
          const nameBytes = enc.encode(f.name);
          const crc = crc32(f.data);
          const size = f.data.length;

          const local = new Uint8Array([
            0x50, 0x4b, 0x03, 0x04,
            ...u16(20), ...u16(0), ...u16(0),
            ...u16(0), ...u16(0),
            ...u32(crc), ...u32(size), ...u32(size),
            ...u16(nameBytes.length), ...u16(0),
            ...nameBytes, ...f.data,
          ]);
          chunks.push(local);
          const localOffset = offset;
          offset += local.length;

          const cd = new Uint8Array([
            0x50, 0x4b, 0x01, 0x02,
            ...u16(20), ...u16(20), ...u16(0), ...u16(0),
            ...u16(0), ...u16(0),
            ...u32(crc), ...u32(size), ...u32(size),
            ...u16(nameBytes.length), ...u16(0), ...u16(0), ...u16(0),
            ...u32(0), ...u32(localOffset), ...nameBytes,
          ]);
          central.push(cd);
        });

        const centralSize = central.reduce((s, c) => s + c.length, 0);
        const centralOffset = offset;

        const end = new Uint8Array([
          0x50, 0x4b, 0x05, 0x06,
          ...u16(0), ...u16(0),
          ...u16(files.length), ...u16(files.length),
          ...u32(centralSize), ...u32(centralOffset), ...u16(0),
        ]);

        return new Blob([...chunks, ...central, end], { type: 'application/zip' });
      }

      async function downloadSelection(): Promise<void> {
        if (selection.length === 0) return;
        try {
          if (selection.length === 1) {
            const item = selection[0];
            const res = await fetch(urlWithColor(item.url));
            const blob = await res.blob();
            triggerDownload(blob, slugToFile(item.slug));
          } else {
            const files = await Promise.all(selection.map(async (item) => {
              const res = await fetch(urlWithColor(item.url));
              const buf = new Uint8Array(await res.arrayBuffer());
              return { name: slugToFile(item.slug), data: buf };
            }));
            triggerDownload(buildZip(files), 'icontree-icons.zip');
          }
        } catch (e) {
          console.error('Download failed:', e);
        }
      }

      cartDownloadBtn?.addEventListener('click', () => { downloadSelection(); });

      buildSwatches();
      renderCart();
    })();
  </script>
</Layout>
