---
import IconPlayer from './IconPlayer.astro';

interface Props {
  name: string;
  slug: string;
  url: string;
}

const { name, slug, url } = Astro.props;
---

<div class="icon-card" tabindex="0" role="button" aria-label={`Add ${name} to selection`}>
  <IconPlayer slug={slug} url={url} name={name} />
  <div class="icon-actions">
    <button class="add-btn" data-add name={name} slug={slug} url={url} aria-label={`Add ${name} to selection`} title="Add to selection">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" />
      </svg>
    </button>
  </div>
  <span class="icon-name">{name}</span>
</div>

<script>
  (function() {
    const cards = Array.from(document.querySelectorAll('.icon-card')) as HTMLElement[];

    cards.forEach((card: HTMLElement) => {
      const addBtn = card.querySelector('.add-btn') as HTMLElement | null;
      const preview = card.querySelector('.icon-preview') as HTMLElement | null;

      function addToCart(e: Event): void {
        e.stopPropagation();
        const url = preview?.getAttribute('data-url');
        const name = preview?.getAttribute('data-name') || '';
        const slug = preview?.getAttribute('data-slug') || '';
        if (!url) return;
        window.dispatchEvent(new CustomEvent('iconadd', { detail: { url, name, slug } }));
        if (addBtn) {
          addBtn.classList.add('added');
          setTimeout(() => addBtn.classList.remove('added'), 600);
        }
      }

      addBtn?.addEventListener('click', addToCart);

      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          addToCart(e);
        }
      });
    });
  })();
</script>
